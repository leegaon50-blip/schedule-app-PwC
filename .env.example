# .env.example — 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 입력하세요.
# .env 는 .gitignore 에 등록되어 있어 GitHub에 올라가지 않습니다.
#
# 이 값들은 Vercel 서버리스 함수(api/*.js)가 `process.env.*` 로 읽습니다.
# - 로컬에서 `vercel dev` 로 실행하면 이 .env 파일을 자동으로 읽습니다 (dotenv 패키지 불필요).
# - 실제 배포(prod) 시에는 Vercel Dashboard > Project > Settings > Environment Variables 에
#   동일한 키를 등록해야 합니다. .env 파일은 배포 서버에 올라가지 않습니다.

# GitHub Personal Access Token (repo 읽기/쓰기 권한)
# 발급: GitHub > Settings > Developer settings > Personal access tokens > Fine-grained tokens
GITHUB_TOKEN=

# 위 토큰이 접근할 저장소 소유자/이름
REPO_OWNER=
REPO_NAME=

# Google AI Studio(aistudio.google.com)에서 발급한 Gemini API 키 (에브리타임 OCR 기능용, 선택)
GEMINI_API_KEY=
